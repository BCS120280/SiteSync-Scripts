{
  "custom": {},
  "params": {},
  "props": {},
  "root": {
    "children": [
      {
        "children": [
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "id": "adapter-api",
                    "type": "close"
                  },
                  "scope": "C",
                  "type": "dock"
                }
              }
            },
            "meta": {
              "name": "close"
            },
            "position": {
              "basis": "30px"
            },
            "props": {
              "path": "material/close"
            },
            "type": "ia.display.icon"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "Label"
                },
                "position": {
                  "grow": 1
                },
                "props": {
                  "style": {
                    "classes": "dark-green-header"
                  },
                  "text": "Adapter API Settings"
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "FlexContainer"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "direction": "column",
              "style": {
                "marginLeft": "3%"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "custom": {
          "PIPath": "",
          "isInPI": false
        },
        "meta": {
          "name": "header"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "style": {
            "backgroundColor": "#8080804D",
            "borderBottomLeftRadius": "12px",
            "borderBottomRightRadius": "12px",
            "borderTopLeftRadius": "12px",
            "borderTopRightRadius": "12px",
            "padding": "3%"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "editItems"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.instances[0].value": {
            "binding": {
              "config": {
                "bidirectional": true,
                "path": "parent.custom.settings.apiURL"
              },
              "type": "property"
            }
          },
          "props.instances[1].value": {
            "binding": {
              "config": {
                "bidirectional": true,
                "path": "parent.custom.settings.datasourceID"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "direction": "column",
          "instances": [
            {
              "instancePosition": {},
              "instanceStyle": {
                "classes": ""
              },
              "label": "API URL"
            },
            {
              "instancePosition": {},
              "instanceStyle": {
                "classes": ""
              },
              "label": "Component ID"
            }
          ],
          "path": "components/settings/components/form-component",
          "style": {
            "borderBottomLeftRadius": "12px",
            "borderBottomRightRadius": "12px",
            "borderColor": "grey",
            "borderStyle": "solid",
            "borderTopLeftRadius": "12px",
            "borderTopRightRadius": "12px",
            "padding": "2%"
          },
          "useDefaultViewWidth": false
        },
        "type": "ia.display.flex-repeater"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tres \u003d adapter.updateAdapterSettings(self.parent.custom.settings)\n\tif utils.isSuccess(res):\n\t\treturn utils.showSuccess(\"Updated\")\n\telse:\n\t\treturn utils.showError(utils.getResultMessage(res))"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "Button"
        },
        "position": {
          "basis": "34px"
        },
        "props": {
          "image": {
            "icon": {
              "path": "material/save"
            }
          },
          "text": "Save"
        },
        "type": "ia.input.button"
      }
    ],
    "custom": {
      "settings": {
        "apiURL": "https://pgwgen002923.mgroupnet.com:5590/api/v1/configuration",
        "datasourceID": "MQTT1",
        "format": "generic",
        "id": 1
      }
    },
    "events": {
      "system": {
        "onStartup": {
          "config": {
            "script": "\tself.custom.settings \u003d adapter.getPICredentials()"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "backgroundColor": "white",
        "margin": "2%",
        "padding": "2%"
      }
    },
    "type": "ia.container.flex"
  }
}