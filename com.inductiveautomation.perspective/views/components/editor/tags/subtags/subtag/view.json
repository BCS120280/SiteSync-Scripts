                    }
                  ],
                  "type": "property"
                }
              },
              "props.color": {
                "binding": {
                  "config": {
                    "path": "/root.custom.isInPi"
                  },
                  "transforms": [
                    {
                      "code": "\tif value:\n\t\treturn \"green\"\n\telse:\n\t\treturn \"red\"\n\treturn value",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              },
              "props.path": {
                "binding": {
                  "config": {
                    "path": "/root.custom.isInPi"
                  },
                  "transforms": [
                    {
                      "code": "\tif value:\n\t\treturn \"material/check_circle\"\n\telse:\n\t\treturn \"material/indeterminate_check_box\"\n\treturn value",
                      "type": "script"
                    }
                  ],
