                  "config": {
                    "script": "\t#system.perspective.sendMessage(\"isTagInPI\")\n\tsystem.perspective.print(\"Starting subtag check {0}\".format(self.view.params.subTagPath))\n\ttry:\n\t\tresult \u003d AF.doesPITagExist(self.view.params.subTagPath)\n\t\tsystem.perspective.print(result)\n\t\tself.view.getChild(\"root\").custom.isInPi \u003d result[\u0027status\u0027]\n\texcept Exception as e:\n\t\tsystem.perspective.print(e)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              },
              "system": {
                "onStartup": {
                  "config": {
                    "script": "\tsystem.perspective.print(\"Starting subtag check {0}\".format(self.view.params.subTagPath))\n\ttry:\n\t\tresult \u003d AF.doesPITagExist(self.view.params.subTagPath)\n\t\tsystem.perspective.print(result)\n\t\tself.view.getChild(\"root\").custom.isInPi \u003d result[\u0027status\u0027]\n\texcept Exception as e:\n\t\tsystem.perspective.print(e)"
                  },
                  "scope": "G",
                  "type": "script"
