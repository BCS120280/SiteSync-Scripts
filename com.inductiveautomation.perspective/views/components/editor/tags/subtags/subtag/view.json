        "borderTopLeftRadius": "12px",
        "borderTopRightRadius": "12px"
      }
    },
    "scripts": {
      "customMethods": [],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "isTagInPI",
          "pageScope": true,
          "script": "\t# implement your handler here\n\tsystem.perspective.print(\"Starting subtag check {0}\".format(self.view.params.subTagPath))\n\ttry:\n\t\tresult \u003d AF.doesPITagExist(self.view.params.subTagPath)\n\t\tself.custom.isInPi \u003d result[\u0027status\u0027]\n\texcept Exception as e:\n\t\tsystem.perspective.print(e)",
          "sessionScope": false,
          "viewScope": false
        },
        {
          "messageType": "refreshPiStatus",
          "pageScope": true,
          "script": "\t# implement your handler here\n\tsystem.perspective.sendMessage(\"isTagInPI\")",
