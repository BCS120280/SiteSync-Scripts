{
  "custom": {},
  "params": {
    "attributeName": "",
    "tagPath": ""
  },
  "propConfig": {
    "params.attributeName": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 80,
      "width": 400
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "breakpoints": [
                {
                  "colIndex": 0,
                  "name": "sm",
                  "order": 1,
                  "rowIndex": 0,
                  "span": 4
                },
                {
                  "colIndex": 0,
                  "name": "md",
                  "order": 1,
                  "rowIndex": 0,
                  "span": 4
                },
                {
                  "colIndex": 0,
                  "name": "lg",
                  "order": 1,
                  "rowIndex": 0,
                  "span": 4
                }
              ],
              "height": 60
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.attributeName"
                  },
                  "type": "property"
                }
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "TextField"
            },
            "position": {
              "breakpoints": [
                {
                  "colIndex": 4,
                  "name": "sm",
                  "order": 2,
                  "rowIndex": 0,
                  "span": 8
                },
                {
                  "colIndex": 4,
                  "name": "md",
                  "order": 2,
                  "rowIndex": 0,
                  "span": 7
                },
                {
                  "colIndex": 4,
                  "name": "lg",
                  "order": 2,
                  "rowIndex": 0,
                  "span": 8
                }
              ],
              "height": "auto"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "bidirectional": true,
                    "fallbackDelay": 2.5,
                    "mode": "indirect",
                    "references": {
                      "tagPath": "{view.params.tagPath}"
                    },
                    "tagPath": "{tagPath}"
                  },
                  "type": "tag"
                }
              }
            },
            "type": "ia.input.text-field"
          }
        ],
        "meta": {
          "name": "ColumnContainer"
        },
        "position": {
          "grow": 1,
          "shrink": 0
        },
        "props": {
          "gutters": {
            "horizontal": 1
          }
        },
        "type": "ia.container.column"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}