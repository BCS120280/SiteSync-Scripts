{
  "custom": {},
  "params": {
    "connectivityText": "this is a message about connectivity",
    "connectivityType": "adapter",
    "successful": false
  },
  "propConfig": {
    "params.connectivityText": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.connectivityType": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.successful": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 120
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "grow": 1
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.connectivityText"
                  },
                  "type": "property"
                }
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Icon",
              "tooltip": {
                "text": "double click to re-try"
              }
            },
            "position": {
              "basis": "30px"
            },
            "propConfig": {
              "props.color": {
                "binding": {
                  "config": {
                    "path": "view.params.successful"
                  },
                  "transforms": [
                    {
                      "code": "\tif value:\n\t\treturn \"green\"\n\treturn \"red\"",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              },
              "props.path": {
                "binding": {
                  "config": {
                    "path": "view.params.successful"
                  },
                  "transforms": [
                    {
                      "code": "\tif value:\n\t\treturn \"material/check_circle\"\n\telse:\n\t\treturn \"material/indeterminate_check_box\"",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "type": "ia.display.icon"
          }
        ],
        "meta": {
          "name": "FlexContainer"
        },
        "position": {
          "shrink": 0
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "Label"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "style": {
            "fontSize": "x-small",
            "fontStyle": "italic"
          },
          "text": "Double click to re-try connection"
        },
        "type": "ia.display.label"
      }
    ],
    "events": {
      "dom": {
        "onDoubleClick": {
          "config": {
            "script": "\tsystem.perspective.sendMessage(\"checkStatus\", payload\u003d{\"type\":self.view.params.connectivityType})"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "justify": "space-between",
      "style": {
        "borderBottomLeftRadius": "12px",
        "borderBottomRightRadius": "12px",
        "borderColor": "grey",
        "borderStyle": "solid",
        "borderTopLeftRadius": "12px",
        "borderTopRightRadius": "12px",
        "margin": "1%",
        "padding": "2%"
      }
    },
    "type": "ia.container.flex"
  }
}